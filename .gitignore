# .gitignore - Combined template: Node, Python, macOS, IDEs

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnp
.pnp.js

# Python
__pycache__/
*.py[cod]
*$py.class
.env
.venv/
venv/
ENV/
env/

# macOS
.DS_Store

# IDEs
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Logs
logs/
*.log

# Build
dist/
build/

# Coverage
coverage/

# Secrets
.env.local
.env.*.local

# Temporary files
*.tmp
*.swp
